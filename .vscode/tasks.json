{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: build project",
      "type": "shell",
      "command": "/usr/bin/clang++",
      "args": [
        "-std=c++17",
        "-g",
        "-Iinclude",
        "src/main.cpp",
        "src/ui.cpp",
        "src/sentiment.cpp",
        "-o",
        "program"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "C++: build server",
      "type": "shell",
      "command": "/usr/bin/clang++",
      "args": [
        "-std=c++17",
        "-g",
        "-Iinclude",
        "src/server.cpp",
        "src/sentiment.cpp",
        "-pthread",
        "-o",
        "server"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    }
  ]
}
